# Set these as Supabase Edge Function secrets (not in the Vite .env):
# supabase secrets set BREVO_API_KEY=...
# supabase secrets set BREVO_SENDER_EMAIL=noreply@yourdomain.com
# supabase secrets set BREVO_SENDER_NAME="Gamer Stronghold"
# supabase secrets set SEND_EMAIL_HOOK_SECRET="v1,whsec_..."

BREVO_API_KEY=your-brevo-api-key
BREVO_SENDER_EMAIL=noreply@yourdomain.com
BREVO_SENDER_NAME=Gamer Stronghold
SEND_EMAIL_HOOK_SECRET=v1,whsec_your-hook-secret

# Optional Brevo template IDs (create templates in Brevo with matching params):
# BREVO_RECOVERY_TEMPLATE_ID=1
# BREVO_SIGNUP_TEMPLATE_ID=2
# BREVO_MAGICLINK_TEMPLATE_ID=3
